# Database - Neon Postgres (Recommended)
# Get your connection strings from: https://neon.tech
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/database?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:password@host.region.aws.neon.tech/database?sslmode=require

# Neon Parameters
PGHOST=your-host-pooler.region.aws.neon.tech
PGHOST_UNPOOLED=your-host.region.aws.neon.tech
PGUSER=your-user
PGDATABASE=your-database
PGPASSWORD=your-password

# Vercel Postgres Compatible Variables (for templates)
POSTGRES_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/database?sslmode=require
POSTGRES_URL_NON_POOLING=postgresql://user:password@host.region.aws.neon.tech/database?sslmode=require
POSTGRES_USER=your-user
POSTGRES_HOST=your-host-pooler.region.aws.neon.tech
POSTGRES_PASSWORD=your-password
POSTGRES_DATABASE=your-database
POSTGRES_URL_NO_SSL=postgresql://user:password@host-pooler.region.aws.neon.tech/database
POSTGRES_PRISMA_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/database?connect_timeout=15&sslmode=require

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=your-blob-token

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://yourchurch.com
NEXT_PUBLIC_SITE_NAME=Fellowship Church
